<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020A22"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVoltar"
                android:layout_width="125dp"
                android:layout_height="48dp"
                android:text="←  VOLTAR"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#071642"
                app:cornerRadius="24dp"
                app:strokeColor="#2962FF"
                app:strokeWidth="1dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="GESTÃO DE\nAVISOS"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFechar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="×"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="#071642"
                app:cornerRadius="24dp"
                app:strokeColor="#2962FF"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/editTitulo"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_input_neon"
            android:drawableStart="@drawable/ic_info_custom"
            android:drawableTint="#7B61FF"
            android:drawablePadding="12dp"
            android:hint="Título do aviso"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8F9BBC"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/editAviso"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_neon"
            android:gravity="top"
            android:hint="Escreva o comunicado aqui..."
            android:padding="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8F9BBC"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="12dp"
            android:text="TIPO DE AVISO"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioTipoAviso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioNormal"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:buttonTint="#7B61FF"
                android:checked="true"
                android:text="NORMAL"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <RadioButton
                android:id="@+id/radioUrgente"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:buttonTint="#FF5C5C"
                android:text="URGENTE"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </RadioGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPublicar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="PUBLICAR AVISO"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#7B61FF"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_send_custom"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AVISOS PUBLICADOS"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textTotalAvisos"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:background="@drawable/bg_badge_vinculo"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="0 avisos"
                android:textColor="#7B61FF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/editBuscarAviso"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_input_neon"
            android:drawableStart="@drawable/ic_search_custom"
            android:drawableTint="#7B61FF"
            android:drawablePadding="12dp"
            android:hint="Buscar aviso pelo título..."
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8F9BBC"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/layoutListaAvisos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIrPainel"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:text="IR PARA PAINEL ADMINISTRATIVO"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#071642"
            app:cornerRadius="28dp"
            app:strokeColor="#2962FF"
            app:strokeWidth="1dp" />

    </LinearLayout>
</ScrollView>