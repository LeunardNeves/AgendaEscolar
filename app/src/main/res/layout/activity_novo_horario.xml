<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_midnight">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnVoltar"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_admin"
                android:text="‹ VOLTAR"
                android:textColor="@color/text_white"
                android:paddingHorizontal="16dp"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="NOVO HORÁRIO"
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnFechar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_admin"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/text_white" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Preencha os dados para adicionar um novo horário"
            android:textColor="#d5e1f5"
            android:textSize="14sp"
            android:layout_marginBottom="25dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DIA DA SEMANA"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layoutDiaSemana"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_item"
            android:gravity="center_vertical"
            android:paddingHorizontal="15dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/electric_blue" />
            <TextView
                android:id="@+id/txtDiaSemana"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Selecione o dia da semana"
                android:textColor="@color/text_white"
                android:textSize="14sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/electric_blue"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HORÁRIO DE INÍCIO"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layoutInicio"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_item"
            android:gravity="center_vertical"
            android:paddingHorizontal="15dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="@color/electric_blue" />
            <TextView
                android:id="@+id/txtInicio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Selecione o horário de início"
                android:textColor="@color/text_white"
                android:textSize="14sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/electric_blue"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HORÁRIO DE TÉRMINO"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layoutTermino"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_item"
            android:gravity="center_vertical"
            android:paddingHorizontal="15dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="@color/electric_blue" />
            <TextView
                android:id="@+id/txtTermino"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Selecione o horário de término"
                android:textColor="@color/text_white"
                android:textSize="14sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/electric_blue"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISCIPLINA"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layoutDisciplina"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_item"
            android:gravity="center_vertical"
            android:paddingHorizontal="15dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_school"
                app:tint="@color/electric_blue" />
            <TextView
                android:id="@+id/txtDisciplina"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Selecione a disciplina"
                android:textColor="@color/text_white"
                android:textSize="14sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/electric_blue"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROFESSOR(A)"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layoutProfessor"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_item"
            android:gravity="center_vertical"
            android:paddingHorizontal="15dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_person"
                app:tint="@color/electric_blue" />
            <TextView
                android:id="@+id/txtProfessor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Selecione o professor(a)"
                android:textColor="@color/text_white"
                android:textSize="14sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/electric_blue"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SALA (OPCIONAL)"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layoutSala"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_item"
            android:gravity="center_vertical"
            android:paddingHorizontal="15dp"
            android:layout_marginBottom="20dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_casa"
                app:tint="@color/electric_blue" />
            <TextView
                android:id="@+id/txtSala"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Selecione a sala (opcional)"
                android:textColor="@color/text_white"
                android:textSize="14sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="@color/electric_blue"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COR DO HORÁRIO"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <View android:layout_width="32dp" android:layout_height="32dp" android:background="@android:color/holo_blue_light" android:layout_marginEnd="12dp"/>
            <View android:layout_width="32dp" android:layout_height="32dp" android:background="@android:color/holo_green_light" android:layout_marginEnd="12dp"/>
            <View android:layout_width="32dp" android:layout_height="32dp" android:background="@android:color/holo_red_light" android:layout_marginEnd="12dp"/>
            <View android:layout_width="32dp" android:layout_height="32dp" android:background="@android:color/holo_orange_light" android:layout_marginEnd="12dp"/>
            <View android:layout_width="32dp" android:layout_height="32dp" android:background="@android:color/holo_purple" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_item"
            android:backgroundTint="#031A4E"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="@color/electric_blue" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DICA"
                    android:textColor="@color/electric_blue"
                    android:textStyle="bold"
                    android:textSize="12sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Você pode identificar seus horários por cores para deixar sua grade mais organizada."
                    android:textColor="#9FA8DA"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSalvarHorario"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_item"
            android:backgroundTint="@color/electric_blue"
            android:text="SALVAR HORÁRIO"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>