<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020A22"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="260dp"
            android:layout_height="120dp"
            android:layout_marginTop="32dp"
            android:scaleType="fitCenter"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="ACESSO\nADMINISTRATIVO"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Entre com o e-mail e senha cadastrados no sistema."
            android:textColor="#AEB9D8"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/editUsuario"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_input_neon"
            android:drawableStart="@drawable/ic_person"
            android:drawableTint="#7B61FF"
            android:drawablePadding="12dp"
            android:hint="E-mail Administrativo"
            android:inputType="textEmailAddress"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8F9BBC"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/editSenha"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_neon"
            android:drawableStart="@drawable/ic_lock"
            android:drawableTint="#7B61FF"
            android:drawablePadding="12dp"
            android:hint="Senha"
            android:inputType="textPassword"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8F9BBC"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEntrar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="ENTRAR"
            android:drawableTint="#7B61FF"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#7B61FF"
            app:cornerRadius="28dp" />

    </LinearLayout>
</ScrollView>