<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020A22"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnVoltar"
                android:layout_width="90dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_voltar"
                android:text="‹  VOLTAR"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="CADASTRO DE\nDOCENTE"
                android:textColor="#FFFFFF"
                android:textSize="21sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Preencha os dados do professor e adicione os vínculos de atuação."
            android:textColor="#AEB9D8"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="NOME DO PROFESSOR"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editNomeProfessor"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_neon"
            android:hint="Digite o nome completo"
            android:inputType="textPersonName"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8F9BBC"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="E-MAIL / LOGIN"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editEmailProfessor"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_neon"
            android:hint="Digite o e-mail ou login"
            android:inputType="textEmailAddress"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8F9BBC"
            android:textSize="15sp" />

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/dropCurso"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_input_neon"
            android:hint="Selecione o curso"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8F9BBC"
            android:textSize="15sp" />

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/dropMateria"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input_neon"
            android:hint="Selecione a matéria"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8F9BBC"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnAdicionarVinculo"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_btn_verde"
            android:text="+ ADICIONAR VÍNCULO"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_card_vinculos"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="VÍNCULOS ADICIONADOS"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutVinculos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textVinculoVazio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="25dp"
                    android:text="Nenhum vínculo adicionado ainda."
                    android:textColor="#8F9BBC"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnSalvarProfessor"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_btn_roxo"
            android:text="SALVAR PROFESSOR"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>