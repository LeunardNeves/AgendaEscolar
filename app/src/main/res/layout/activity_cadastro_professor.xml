<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradiente">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnVoltar"
                android:layout_width="88dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_item"
                android:text="VOLTAR"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CADASTRO DE\nDOCENTE"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:textStyle="bold"
                android:gravity="center" />

            <Space
                android:layout_width="88dp"
                android:layout_height="46dp" />
        </LinearLayout>

        <TextView
            android:text="NOME DO PROFESSOR"
            android:textColor="#C9D3F5"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/editNomeProfessor"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/bg_item"
            android:hint="Digite o nome completo"
            android:textColorHint="#8A99AD"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="18dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:text="E-MAIL / LOGIN"
            android:textColor="#C9D3F5"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/editEmailProfessor"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/bg_item"
            android:hint="Digite o e-mail ou login"
            android:textColorHint="#8A99AD"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="18dp"
            android:inputType="textEmailAddress"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutCurso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Selecione o curso"
            android:layout_marginBottom="18dp"
            app:boxBackgroundColor="#061A4A"
            app:boxStrokeColor="#7B61FF"
            app:hintTextColor="#C9D3F5"
            app:endIconMode="dropdown_menu"
            app:boxCornerRadiusTopStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusBottomEnd="18dp">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/dropCurso"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:inputType="none"
                android:textColor="#FFFFFF"
                android:textColorHint="#8A99AD"
                android:paddingHorizontal="18dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutMateria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Selecione a matéria"
            android:layout_marginBottom="22dp"
            app:boxBackgroundColor="#061A4A"
            app:boxStrokeColor="#7B61FF"
            app:hintTextColor="#C9D3F5"
            app:endIconMode="dropdown_menu"
            app:boxCornerRadiusTopStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusBottomEnd="18dp">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/dropMateria"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:inputType="none"
                android:textColor="#FFFFFF"
                android:textColorHint="#8A99AD"
                android:paddingHorizontal="18dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAdicionarVinculo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_item"
            android:backgroundTint="#00BFA6"
            android:text="+ ADICIONAR VÍNCULO"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:text="VÍNCULOS ADICIONADOS"
            android:textColor="#C9D3F5"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/layoutVinculos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="28dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSalvarProfessor"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@drawable/bg_item"
            android:backgroundTint="#7B61FF"
            android:text="SALVAR PROFESSOR"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>