<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020A22"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/logo_eetepa"
            android:layout_width="320dp"
            android:layout_height="145dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/logoescolar1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Bem-vindo ao Sistema"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="de Horários Escolares"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EETEPA CURUÇÁ"
            android:textColor="#AEB9D8"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="26dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPainelAdmin"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:layout_marginBottom="28dp"
            android:text="Acessar Painel ADM"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#071642"
            app:cornerRadius="26dp"
            app:strokeColor="#7B61FF"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:id="@+id/layoutCurso"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/bg_input_neon"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="18dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_school"
                app:tint="#7B61FF" />

            <TextView
                android:id="@+id/txtCurso"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Selecione o Curso"
                android:textColor="#AEB9D8"
                android:textSize="15sp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_expand_more_custom"
                app:tint="#7B61FF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutAno"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/bg_input_neon"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="18dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_calendar_custom"
                app:tint="#7B61FF" />

            <TextView
                android:id="@+id/txtAno"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Selecione o Ano/Módulo"
                android:textColor="#AEB9D8"
                android:textSize="15sp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_expand_more_custom"
                app:tint="#7B61FF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutTurno"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/bg_input_neon"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="18dp"
            android:layout_marginBottom="30dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_clock_custom"
                app:tint="#7B61FF" />

            <TextView
                android:id="@+id/txtTurno"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Selecione o Turno"
                android:textColor="#AEB9D8"
                android:textSize="15sp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_expand_more_custom"
                app:tint="#7B61FF" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinuar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Salvar e Continuar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#7B61FF"
            app:cornerRadius="28dp"
            app:iconGravity="textEnd"
            app:iconPadding="10dp"
            app:iconTint="#FFFFFF" />

    </LinearLayout>
</ScrollView>